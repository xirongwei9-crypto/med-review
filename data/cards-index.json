      {
        "id": "gpw-q1",
        "type": "single",
        "question": "革兰阳性菌细胞壁的主要成分是？",
        "options": ["A. 脂多糖", "B. 肽聚糖和磷壁酸", "C. 脂蛋白", "D. 孔蛋白"],
        "answer": "B. 肽聚糖和磷壁酸",
        "explanation": "G+菌细胞壁由厚层肽聚糖（15-50层）和磷壁酸组成，无外膜和脂多糖。"
      },
      {
        "id": "gpw-q2",
        "type": "single",
        "question": "关于革兰阳性菌细胞壁，错误的是？",
        "options": ["A. 肽聚糖层厚", "B. 含磷壁酸", "C. 含有脂多糖", "D. 对溶菌酶敏感"],
        "answer": "C. 含有脂多糖",
        "explanation": "脂多糖（LPS）是革兰阴性菌外膜的成分，G+菌没有LPS。"
      }
    ]
  },
