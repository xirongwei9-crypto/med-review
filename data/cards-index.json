      {
        "id": "tca-q1",
        "type": "single",
        "question": "T细胞活化的第二信号是？",
        "options": ["A. TCR识别MHC-抗原肽", "B. CD28结合B7", "C. CD4结合MHC-II", "D. IL-2与受体结合"],
        "answer": "B. CD28结合B7",
        "explanation": "第一信号是TCR识别MHC-抗原肽复合物，第二信号是CD28（T细胞）结合B7/CD80-CD86（APC），缺少第二信号导致T细胞无能。"
      },
      {
        "id": "tca-q2",
        "type": "single",
        "question": "关于CTLA-4的作用，正确的是？",
        "options": ["A. 正性共刺激分子", "B. 促进IL-2分泌", "C. 竞争性结合B7，免疫负调控", "D. 与MHC-II结合"],
        "answer": "C. 竞争性结合B7，免疫负调控",
        "explanation": "CTLA-4是免疫检查点分子，与CD28竞争结合B7且亲和力更高，起免疫负调控（\"踩刹车\"）作用。"
      }
    ]
